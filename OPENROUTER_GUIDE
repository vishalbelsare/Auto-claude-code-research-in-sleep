  -H "Content-Type: application/json" \
  -H "Authorization: Bearer sk-or-v1-your-key" \
  -d '{
    "model": "openrouter/free",
    "messages": [{"role": "user", "content": "Say hello"}],
    "max_tokens": 50
  }'
